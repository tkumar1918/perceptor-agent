// ============================================================================
// Perceptor VM AGENT — deploy on a project's VM (one per host).
//
// Collects THIS VM's host + container metrics & logs and ships them to the
// PROJECT's tenant, tagged telemetry_source=infra so they sit alongside — and
// correlate with — the project's app telemetry without being mistaken for it.
//
// Unlike the CENTRAL agent (which direct-writes to internal Mimir/Loki), a
// remote VM reaches the platform ONLY through the authenticated edge: it pushes
// OTLP to Caddy with the project's bearer token, and Caddy stamps the tenant.
// The VM is never trusted to name its own tenant.
//
// Required env (see .env.example): EDGE_ENDPOINT, PROJECT_TOKEN, VM_NAME
// ============================================================================

// ── Host metrics (CPU/RAM/disk/net) ────────────────────────────────────────
prometheus.exporter.unix "host" {
	rootfs_path = "/host/root"
	procfs_path = "/host/proc"
	sysfs_path  = "/host/sys"

	// Two opt-in node_exporter collectors (off by default):
	//   systemd   — per-unit state: is nginx.service / the app's unit up, dead,
	//               or failed? It reads this over the host's D-Bus socket, so it
	//               needs the /run/dbus/system_bus_socket mount (see compose) —
	//               without it the collector loads but emits nothing.
	//   processes — aggregate process/thread COUNTS (running, blocked, zombies)
	//               from /host/proc. NOT a per-process list — no pid/name/cpu.
	//               For "which process is hot" on a Dockerised box, cadvisor's
	//               per-container metrics are the right tool.
	enable_collectors = ["systemd", "processes"]

	filesystem {
		mount_points_exclude = "^/(dev|proc|sys|host/proc|host/sys|run|var/lib/docker/.+)($|/)"
		fs_types_exclude     = "^(autofs|binfmt_misc|bpf|cgroup2?|configfs|debugfs|devpts|devtmpfs|fusectl|hugetlbfs|mqueue|nsfs|overlay|proc|procfs|pstore|securityfs|selinuxfs|squashfs|sysfs|tmpfs|tracefs)$"
	}
}

// ── Container metrics (needs cgroup + containerd mounts — see compose) ─────
prometheus.exporter.cadvisor "containers" {
	docker_host            = "unix:///var/run/docker.sock"
	docker_only            = true
	store_container_labels = false

	// store_container_labels=false drops ALL container labels from metrics (they
	// are a classic cardinality bomb). Let exactly ONE back through: the env
	// marker, so dev and prod containers can be told apart on a shared VM. The
	// allowlist is the surgical alternative to turning every label back on.
	// cadvisor exposes it as the metric label container_label_perceptor_environment,
	// which prometheus.relabel.infra normalizes to `environment` below.
	allowlisted_container_labels = ["perceptor.environment"]
}

// ── Scrape both, give containers a `container` label, hand off to OTLP ─────
prometheus.scrape "infra" {
	targets = concat(
		prometheus.exporter.unix.host.targets,
		prometheus.exporter.cadvisor.containers.targets,
	)
	scrape_interval = "15s"
	forward_to      = [prometheus.relabel.infra.receiver]
}

prometheus.relabel "infra" {
	forward_to = [otelcol.receiver.prometheus.infra.receiver]

	rule {
		source_labels = ["name"]
		target_label  = "container"
	}

	// environment (dev/prod), so a shared VM's dev and prod containers separate
	// cleanly. Prefer the EXPLICIT compose label perceptor.environment (surfaced
	// as container_label_perceptor_environment by the cadvisor allowlist); if
	// it's absent, best-effort a dev/prod token from the container name. The
	// explicit label always wins: the fallback rules are gated on `environment`
	// still being empty (they match only when the joined value starts with the
	// separator), and a token must be delimiter-bounded so `development` or
	// `code-server` don't get mislabelled.
	rule {
		source_labels = ["container_label_perceptor_environment"]
		regex         = "(.+)"
		target_label  = "environment"
	}
	rule {
		source_labels = ["environment", "container"]
		regex         = ";(.*[-_.])?dev([-_.].*)?"
		target_label  = "environment"
		replacement   = "dev"
	}
	rule {
		source_labels = ["environment", "container"]
		regex         = ";(.*[-_.])?prod([-_.].*)?"
		target_label  = "environment"
		replacement   = "prod"
	}
	// Drop the raw cadvisor label now it's normalized into `environment`.
	rule {
		regex  = "container_label_perceptor_environment"
		action = "labeldrop"
	}

	// Stable identity: by default `instance` is this container's hex id, which
	// changes every recreate — churning EVERY series in the project's tenant.
	// Pin it to the VM name; `job` still separates the unix vs cadvisor exporters.
	rule {
		target_label = "instance"
		replacement  = coalesce(sys.env("VM_NAME"), "unknown-vm")
	}
}

otelcol.receiver.prometheus "infra" {
	output {
		metrics = [otelcol.processor.attributes.tag.input]
	}
}

// ── Host logs (journald) ───────────────────────────────────────────────────
discovery.relabel "journal" {
	targets = []

	rule {
		source_labels = ["__journal__systemd_unit"]
		target_label  = "unit"
	}

	// Without this, host/journal logs land in Loki as `unknown_service` — they
	// carry no service_name, unlike container logs (which default it to the
	// container name). Give them one: the systemd unit (e.g. sshd.service),
	// falling back to a fixed `systemd-journal` for unit-less entries (kernel,
	// early boot). It crosses OTLP as service_name and the shared transform below
	// hoists it to resource service.name — the exact path the container logs use.
	rule {
		source_labels = ["__journal__systemd_unit"]
		target_label  = "service_name"
	}
	rule {
		source_labels = ["service_name"]
		regex         = "^$"
		target_label  = "service_name"
		replacement   = "systemd-journal"
	}
}

loki.source.journal "host" {
	max_age       = "12h"
	relabel_rules = discovery.relabel.journal.rules
	labels        = { job = "systemd-journal" }
	forward_to    = [otelcol.receiver.loki.infra.receiver]
}

// ── Container logs (docker) — OPT-IN: only containers that ask to be collected ──
discovery.docker "containers" {
	host = "unix:///var/run/docker.sock"
}

discovery.relabel "containers" {
	targets = discovery.docker.containers.targets

	// Never ingest our OWN logs. A collector that reads its own stderr will
	// amplify into a runaway feedback loop the moment the edge backpressures:
	// export fails -> logs an error -> reads that error back in -> exports it ->
	// fails -> ... (this pegged a whole host at 800%+ CPU in testing). Drop self.
	// (Also excluded by the opt-in keep below — this is a belt-and-braces guard.)
	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/perceptor-agent"
		action        = "drop"
	}

	// OPT-IN: collect a container's logs ONLY if it explicitly sets
	//   labels: { perceptor.enable: "true" }   in its own compose.
	// A `keep` drops every target whose label doesn't match — so by default,
	// with no label, a container's stdout is NEVER scraped. This is deliberate:
	// on a shared VM you don't want to slurp third-party/app logs (which may hold
	// secrets or PII) just because a container exists. Owners opt in per service.
	rule {
		source_labels = ["__meta_docker_container_label_perceptor_enable"]
		regex         = "true"
		action        = "keep"
	}
	// Identity. Always set `container`, and default `service_name` to the container
	// name too — so a container that opts in but never declares perceptor.service_name
	// still gets a real name instead of collapsing into Loki's `unknown_service`.
	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/(.*)"
		target_label  = "container"
	}
	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/(.*)"
		target_label  = "service_name"
	}
	// A declared perceptor.service_name overrides the default. regex "(.+)" matches
	// only a non-empty value, so an absent label leaves the default untouched.
	rule {
		source_labels = ["__meta_docker_container_label_perceptor_service_name"]
		regex         = "(.+)"
		target_label  = "service_name"
	}

	// environment (dev/prod) — same derivation as the metrics path, so a log
	// line and its container's metrics carry the same label. Explicit compose
	// label preferred; dev/prod name-token fallback, gated on `environment`
	// still being empty. (docker container names arrive with a leading "/",
	// harmlessly absorbed by the fallback's leading .* )
	rule {
		source_labels = ["__meta_docker_container_label_perceptor_environment"]
		regex         = "(.+)"
		target_label  = "environment"
	}
	rule {
		source_labels = ["environment", "__meta_docker_container_name"]
		regex         = ";(.*[-_.])?dev([-_.].*)?"
		target_label  = "environment"
		replacement   = "dev"
	}
	rule {
		source_labels = ["environment", "__meta_docker_container_name"]
		regex         = ";(.*[-_.])?prod([-_.].*)?"
		target_label  = "environment"
		replacement   = "prod"
	}
}

loki.source.docker "containers" {
	host       = "unix:///var/run/docker.sock"
	targets    = discovery.relabel.containers.output
	labels     = { job = "docker" }
	forward_to = [otelcol.receiver.loki.infra.receiver]
}

// ── nginx host logs (files) — ONLY if nginx runs as a HOST service ─────────
// nginx writes access/error logs to /var/log/nginx/*.log; when it runs on the
// host (not in a container) those never reach docker/journald, so we tail them
// off the mounted host root. A containerised nginx is already covered by
// loki.source.docker above — this is purely for the host-service case, and is a
// harmless no-op on a VM with no such files. Rides the same OTLP path into the
// infra tenant, tagged job=nginx and service_name=nginx (so it gets a real name
// instead of Loki's unknown_service, same as the journal path above).
local.file_match "nginx" {
	path_targets = [{ __path__ = "/host/root/var/log/nginx/*.log", job = "nginx", service_name = "nginx" }]
}

loki.source.file "nginx" {
	targets    = local.file_match.nginx.targets
	forward_to = [otelcol.receiver.loki.infra.receiver]
}

otelcol.receiver.loki "infra" {
	output {
		logs = [otelcol.processor.groupbyattrs.svc.input]
	}
}

// Give each container's logs their OWN resource, keyed by the identity labels.
// (loki.source.docker emits per-container streams; groupbyattrs promotes these
// attributes to the resource level so the next step can set a per-container
// service.name without one container's value clobbering another's.)
otelcol.processor.groupbyattrs "svc" {
	keys = ["service_name"]
	output {
		logs = [otelcol.processor.transform.svc.input]
	}
}

// THE service.name FIX. Loki derives its indexed `service_name` label from the
// OTLP RESOURCE attribute `service.name`, and defaults to `unknown_service` when
// it's absent. The relabel above set a `service_name` *log label*, which crosses
// OTLP as a log-record attribute and COLLIDES with Loki's reserved name — so Loki
// keeps its own (`unknown_service`, collapsing every container into one) and
// renames ours to `service_name_extracted`. Fix: hoist it to the resource
// `service.name` (falling back to the container name), and drop the colliding key.
otelcol.processor.transform "svc" {
	error_mode = "ignore"
	log_statements {
		context = "resource"
		statements = [
			`set(resource.attributes["service.name"], resource.attributes["service_name"])`,
			`delete_key(resource.attributes, "service_name")`,
		]
	}
	output {
		logs = [otelcol.processor.attributes.tag.input]
	}
}

// ── Tag telemetry_source + vm, then push OTLP to the edge (Caddy) ─────────
otelcol.processor.attributes "tag" {
	action {
		key    = "telemetry_source"
		value  = "infra"
		action = "upsert"
	}
	action {
		key    = "vm"
		value  = sys.env("VM_NAME")
		action = "upsert"
	}

	output {
		metrics = [otelcol.exporter.otlphttp.edge.input]
		logs    = [otelcol.exporter.otlphttp.edge.input]
	}
}

// Project ingest token — Caddy maps it to the tenant and stamps X-Scope-OrgID.
otelcol.auth.bearer "token" {
	token = sys.env("PROJECT_TOKEN")
}

otelcol.exporter.otlphttp "edge" {
	client {
		endpoint = sys.env("EDGE_ENDPOINT") // e.g. https://lgtm.runtheday.com
		auth     = otelcol.auth.bearer.token.handler
	}
}
